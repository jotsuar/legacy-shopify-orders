# ══════════════════════════════════════════════════════════════
#  Shopify Orders — Legacy (Laravel 11)
#  Copia este archivo a .env y completa los valores reales.
#  cp .env.example .env
#  php artisan key:generate   ← genera APP_KEY automáticamente
# ══════════════════════════════════════════════════════════════

# ─── Aplicación ───────────────────────────────────────────────
APP_NAME="Shopify Legacy"
APP_ENV=local
# Generar con: php artisan key:generate --show
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# ─── Logs ─────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=debug

# ─── Base de datos (PostgreSQL) ───────────────────────────────
# Misma instancia que el backend NestJS — acceso de solo lectura.
# Host local si corres Postgres directamente:
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=shopify_orders
DB_USERNAME=shopify_user
DB_PASSWORD=shopify_pass

# ─── Sesión / Caché / Cola ────────────────────────────────────
# Configuración mínima — este servicio no gestiona sesiones de usuario.
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
CACHE_STORE=array
QUEUE_CONNECTION=sync

# ─── L5-Swagger (OpenAPI) ─────────────────────────────────────
# Regenera automáticamente el JSON de documentación en cada request.
# Poner false en producción para mejor rendimiento.
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_UI_ASSETS_PATH=vendor/swagger-api/swagger-ui/dist/
# Título que aparece en la UI de Swagger
L5_SWAGGER_UI_DOC_EXPANSION=none
